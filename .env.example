# Copie para .env.local e preencha. Variáveis VITE_ ficam expostas no client —
# use chaves/tokens com uso restrito.

# Supabase
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# OpenRouteService (rotas no mapa)
VITE_ORS_API_KEY=

# TMDB — pôsteres da "Nossa Sessão". Configure UM dos dois:
#   VITE_TMDB_TOKEN → "API Read Access Token" (v4, recomendado)
#   VITE_TMDB_KEY   → "API Key" (v3)
# Pegue em https://www.themoviedb.org/settings/api
# Sem nenhum, os cards caem no fallback de cor sólida (nada quebra).
VITE_TMDB_TOKEN=
VITE_TMDB_KEY=
